rules_version = '2';
// Paste this into: Firebase console > Firestore Database > Rules > Publish.
// This is the MERGED ruleset for Ryan's existing Firebase project: it keeps the
// pre-existing `polls` and `wordclouds` apps working and adds the Connections game.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Existing apps (unchanged) ----
    match /polls/{pollId} {
      allow read, write: if true;
    }
    match /wordclouds/{cloudId} {
      allow read, write: if true;
    }

    // ---- Connections game ----
    // Puzzles: anyone can read (to play); only a signed-in host can write.
    match /puzzles/{date} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Which puzzle is live: readable by all, writable only by the host.
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Results: anyone reads the leaderboard and can submit their own result;
    // only the signed-in host can delete results.
    match /results/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ---- Catch-all: deny everything else (MUST stay last) ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
